<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/ripple_loai_hang">

    <!-- Image Container with CardView -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardImageContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@android:color/white">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivHinhAnh"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/slide_image1"
                tools:ignore="ContentDescription" />

            <!-- Overlay for selected state -->
            <View
                android:id="@+id/viewOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/BrowPrimary"
                android:alpha="0.4"
                android:visibility="gone" />

            <!-- Check icon for selected state -->
            <ImageView
                android:id="@+id/ivCheckMark"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|top"
                android:layout_margin="6dp"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Category Name -->
    <TextView
        android:id="@+id/tvTenLoaiHang"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cà phê"
        android:textSize="13sp"
        android:textColor="@color/BlackPrimary"
        android:fontFamily="@font/inter_bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        tools:ignore="HardcodedText" />

    <!-- Hidden TextView for maLoai (still accessible in code) -->
    <TextView
        android:id="@+id/tvMaLoaiHang"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
