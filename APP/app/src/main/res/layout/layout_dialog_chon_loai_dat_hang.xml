<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tiêu đề -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="Chọn loại đặt hàng"
            android:textColor="@color/BlackPrimary"
            android:textSize="20sp"
            tools:ignore="HardcodedText" />

        <!-- Mô tả -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="Bạn muốn đặt hàng như thế nào?"
            android:textColor="@color/Gray1Primary"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

        <!-- Tên món đã chọn -->
        <TextView
            android:id="@+id/tvTenMon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="Cà phê đen"
            android:textColor="@color/BrowPrimary"
            android:textSize="16sp"
            android:visibility="gone"
            tools:ignore="HardcodedText" />

        <!-- Nút Chọn bàn -->
        <Button
            android:id="@+id/btnChonBan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bgr_btn_brow1_rd5"
            android:fontFamily="@font/inter_bold"
            android:text="Chọn bàn"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:ignore="HardcodedText" />

        <!-- Nút Mang về -->
        <Button
            android:id="@+id/btnMangVe"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bgr_btn_brow1_rd5"
            android:fontFamily="@font/inter_bold"
            android:text="Mang về"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:ignore="HardcodedText" />

        <!-- Nút Hủy -->
        <TextView
            android:id="@+id/tvHuy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="Hủy"
            android:textColor="@color/BluePrimary"
            android:textSize="16sp"
            android:padding="12dp"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</androidx.cardview.widget.CardView>

