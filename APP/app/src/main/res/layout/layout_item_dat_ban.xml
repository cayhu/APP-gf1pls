<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_quan_ly_ban_24_brow"
            android:layout_marginEnd="16dp"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMaBan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bàn 1"
                android:textColor="@color/BlackPrimary"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvNgay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ngày: 01/01/2025"
                android:textColor="@color/BlackPrimary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvGio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giờ: 10:00"
                android:textColor="@color/BlackPrimary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvGhiChu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ghi chú: ..."
                android:textColor="@color/Gray1Primary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                android:visibility="gone"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTrangThai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đã duyệt"
            android:textColor="@color/WhitePrimary"
            android:textSize="12sp"
            android:padding="8dp"
            android:minWidth="80dp"
            android:gravity="center"
            tools:ignore="HardcodedText" />

    </LinearLayout>

</androidx.cardview.widget.CardView>

