<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tiêu đề -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="Chọn bàn của bạn"
            android:textColor="@color/BlackPrimary"
            android:textSize="20sp"
            tools:ignore="HardcodedText" />

        <!-- Mô tả -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="Chọn bàn đã đặt và đã được duyệt"
            android:textColor="@color/Gray1Primary"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

        <!-- Danh sách bàn -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewBan"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="true"
            tools:listitem="@layout/layout_item_dat_ban" />

        <!-- Text trống -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="Bạn chưa có bàn nào đã được duyệt"
            android:textColor="@color/Gray1Primary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:ignore="HardcodedText" />

        <!-- Nút Hủy -->
        <TextView
            android:id="@+id/tvHuy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="Hủy"
            android:textColor="@color/BluePrimary"
            android:textSize="16sp"
            android:padding="12dp"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</androidx.cardview.widget.CardView>

